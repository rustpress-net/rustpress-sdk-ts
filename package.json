{
  "name": "@rustpress/sdk",
  "version": "1.0.0",
  "description": "Official TypeScript SDK for RustPress - Build hooks, plugins, themes, and apps",
  "main": "dist/index.js",
  "module": "dist/index.mjs",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./hooks": {
      "import": "./dist/hooks/index.mjs",
      "require": "./dist/hooks/index.js",
      "types": "./dist/hooks/index.d.ts"
    },
    "./plugins": {
      "import": "./dist/plugins/index.mjs",
      "require": "./dist/plugins/index.js",
      "types": "./dist/plugins/index.d.ts"
    },
    "./database": {
      "import": "./dist/database/index.mjs",
      "require": "./dist/database/index.js",
      "types": "./dist/database/index.d.ts"
    },
    "./api": {
      "import": "./dist/api/index.mjs",
      "require": "./dist/api/index.js",
      "types": "./dist/api/index.d.ts"
    }
  },
  "bin": {
    "rustpress": "./dist/cli.js"
  },
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts src/hooks/index.ts src/plugins/index.ts src/database/index.ts src/api/index.ts --format cjs,esm --dts --clean",
    "dev": "tsup src/index.ts src/cli.ts src/hooks/index.ts src/plugins/index.ts src/database/index.ts src/api/index.ts --format cjs,esm --dts --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "rustpress",
    "cms",
    "sdk",
    "typescript",
    "hooks",
    "plugins",
    "themes"
  ],
  "author": "RustPress Team",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rustpress/rustpress-sdk-ts"
  },
  "homepage": "https://rustpress.dev/docs/sdk/typescript",
  "bugs": {
    "url": "https://github.com/rustpress/rustpress-sdk-ts/issues"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0",
    "eslint": "^8.56.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0"
  },
  "peerDependencies": {
    "typescript": ">=4.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "bin",
    "README.md",
    "LICENSE"
  ]
}
